# Copy this file to .env and fill in your keys
# Get ZeroDev Project ID from: https://dashboard.zerodev.app
VITE_ZERODEV_PROJECT_ID=your_zerodev_project_id_here
VITE_ZERODEV_BUNDLER_URL=https://rpc.zerodev.app/api/v3/YOUR_PROJECT_ID/chain/84532

# Get Web3Auth Client ID from: https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here
VITE_WEB3AUTH_NETWORK=sapphire_devnet
.
